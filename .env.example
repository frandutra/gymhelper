# Supabase — copiá este archivo a .env.local y completá con tus valores.
# Settings > API en el dashboard de Supabase.

# URL del proyecto (ej. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable / anon key (segura para el cliente; la protección real la da RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Connection string de Postgres para Drizzle (Connect > ORMs en Supabase).
# Incluye el password de la base. Usar el pooler (puerto 6543).
# postgresql://postgres.<ref>:[PASSWORD]@aws-...pooler.supabase.com:6543/postgres
DATABASE_URL=

# Service role / secret key — SOLO server-side, nunca al cliente.
# La usa el seed de ejercicios (scripts/seed-exercises.ts) para saltar RLS.
SUPABASE_SERVICE_ROLE_KEY=
